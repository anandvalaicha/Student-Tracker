# ── Frontend (set these in Netlify → Site configuration → Environment variables) ──
# The full URL of your deployed backend (no trailing slash)
VITE_API_URL=https://your-render-app.onrender.com

# ── Backend (set these in Render → Environment) ──────────────────────────────
# The full URL of your Netlify frontend (no trailing slash)
CLIENT_URL=https://your-app.netlify.app

# Optional: change this to a long random string in production
JWT_SECRET=change-me-in-production
